{
  "manifest_version": 3,
  "name": "__MSG_ext_name__",
  "version": "2.0.0",
  "description": "__MSG_ext_description__",
  "default_locale": "en",

  "permissions": [
    "activeTab",
    "storage",
    "sidePanel"
  ],

  "host_permissions": [
    "https://kdp.amazon.com/*"
  ],

  "action": {
    "default_title": "KDP X-Ray Helper",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },

  "content_scripts": [
    {
      "matches": ["https://kdp.amazon.com/xray/verify/*"],
      "js": [
        "shared/constants.js",
        "content/dom-reader.js",
        "content/dom-writer.js",
        "content/batch-executor.js",
        "content/content.js"
      ],
      "run_at": "document_idle"
    }
  ],

  "options_page": "options/options.html",

  "background": {
    "service_worker": "background.js"
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
